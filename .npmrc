auto-install-peers=true
strict-peer-dependencies=false

# Block packages published less than 7 days ago (supply chain protection)
min-release-age=7

# Publishing: Trusted Publisher (OIDC) + Staged Publishing.
# No long-lived NPM_TOKEN needed. CI stages @gmc-cli/cli via `npm stage publish`;
# the maintainer approves with their passkey at npmjs.com before it goes live.
# Requires (npm-side, not in this repo): a Trusted Publisher configured on the
# @gmc-cli/cli package (org yasserstudio, repo gmc, workflow release.yml) AND
# 2FA enabled on the @gmc-cli npm org — mirror the working @gpc-cli setup.
