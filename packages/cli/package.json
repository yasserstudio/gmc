{
  "name": "@gmc-cli/cli",
  "version": "0.9.3",
  "description": "Google Merchant Center CLI — a typed, CI-friendly command-line interface for the Google Merchant API, with an offline feed-compliance preflight. Provides the gmc command.",
  "type": "module",
  "bin": {
    "gmc": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gmc-cli/api": "workspace:*",
    "@gmc-cli/auth": "workspace:*",
    "@gmc-cli/config": "workspace:*",
    "@gmc-cli/core": "workspace:*",
    "@gmc-cli/preflight": "workspace:*",
    "commander": "^14.0.3"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "google-shopping",
    "product-feed",
    "cli",
    "ecommerce",
    "feed",
    "preflight",
    "content-api-migration",
    "merchant-center-next",
    "devops",
    "ci-cd",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
