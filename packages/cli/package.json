{
  "name": "@gmc-cli/cli",
  "version": "1.0.16",
  "description": "Free, open-source CLI for the Google Merchant API. Migrate off the retiring Content API, diagnose silent setup failures (gmc doctor), and preflight feeds offline to catch disapprovals before upload — typed, --json, CI-native. Provides the gmc command.",
  "type": "module",
  "bin": {
    "gmc": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "google-auth-library": "^10.7.0"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "merchant-api-migration",
    "content-api-shopping",
    "content-api-migration",
    "google-shopping",
    "google-shopping-feed",
    "product-feed",
    "feed-validation",
    "feed-validator",
    "preflight",
    "cli",
    "ecommerce",
    "merchant-center-next",
    "devops",
    "ci-cd",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@gmc-cli/api": "workspace:*",
    "@gmc-cli/auth": "workspace:*",
    "@gmc-cli/config": "workspace:*",
    "@gmc-cli/core": "workspace:*",
    "@gmc-cli/migrate": "workspace:*",
    "@gmc-cli/mcp": "workspace:*",
    "@gmc-cli/preflight": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/gmc.git",
    "directory": "packages/cli"
  }
}
