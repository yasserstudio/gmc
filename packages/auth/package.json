{
  "name": "@gmc-cli/auth",
  "private": true,  "version": "0.7.1",
  "description": "Google Merchant API authentication for Node.js. Service account, OAuth 2.0, and Application Default Credentials with per-sub-API scopes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "auth",
    "service-account",
    "oauth",
    "google-auth",
    "application-default-credentials"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "google-auth-library": "^10.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
