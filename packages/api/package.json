{
  "name": "@gmc-cli/api",
  "version": "0.8.0",
  "description": "TypeScript client for the Google Merchant API (Products, Inventories, Reports, Accounts, Promotions, Quota). Typed requests and responses, rate limiting.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gmc-cli/auth": "workspace:*"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "google-shopping",
    "api-client",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@gmc-cli/auth": "workspace:*",
    "@types/node": "^25.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
