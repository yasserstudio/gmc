{
  "name": "@gmc-cli/preflight",
  "private": true,
  "version": "0.1.21",
  "description": "Offline feed-compliance scanner for the Google Merchant Center CLI — checks required attributes, formats, and disapproval triggers before upload.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "preflight",
    "feed-validation",
    "product-feed",
    "disapproval",
    "compliance"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gmc-cli/api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
