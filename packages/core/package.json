{
  "name": "@gmc-cli/core",
  "version": "0.7.10",
  "description": "Core business logic for the Google Merchant Center CLI — command orchestration, doctor checks, offline preflight scanner, and feed diffing for the Google Merchant API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gmc-cli/api": "workspace:*",
    "@gmc-cli/auth": "workspace:*",
    "@gmc-cli/config": "workspace:*"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "preflight",
    "feed",
    "doctor",
    "migrate",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
