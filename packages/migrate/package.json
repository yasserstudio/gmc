{
  "name": "@gmc-cli/migrate",
  "private": true,
  "version": "0.1.9",
  "description": "Content API for Shopping → Merchant API migration engine for the Google Merchant Center CLI — scope mapping, legacy-config import, and product remapping.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "content-api-migration",
    "content-api-for-shopping",
    "product-feed",
    "migration"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gmc-cli/api": "workspace:*",
    "@gmc-cli/auth": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
