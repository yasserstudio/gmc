{
  "name": "@gmc-cli/config",
  "private": true,
  "version": "0.7.1",
  "description": "Configuration loading, validation, profiles, and environment variable support for the Google Merchant Center CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gmc/",
  "keywords": [
    "google-merchant-center",
    "merchant-api",
    "config",
    "profiles",
    "environment-variables"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gmc"
  }
}
